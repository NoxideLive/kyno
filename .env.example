# Clerk (frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk sign-in URLs (optional — defaults shown)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Public site URL for Clerk allowedRedirectOrigins (optional — localhost added by default)
# VITE_SITE_URL=https://your-app.example.com
# Also add http://localhost:5173 in Clerk Dashboard → Configure → Paths → Allowed redirect origins

# =============================================================================
# Production (cloud Convex)
# =============================================================================
# VITE_CONVEX_URL=https://your-deployment.convex.cloud

# =============================================================================
# Local dev — Docker Compose dev profile (see docs/local-dev-docker.md)
# Copy these into .env.local when using: docker compose --env-file .env.local up
# =============================================================================
# VITE_CONVEX_URL=http://localhost:3210
# VITE_CONVEX_SITE_URL=http://localhost:3211

# Phi gateway (compose + host scripts like run_domain_pipeline.py)
# PHI_GATEWAY_API_KEY=your-secret          # required for POST /admin/reload-prompts during compact tuning
# PHI_GATEWAY_PORT=8090
# PHI_GATEWAY_PROFILE=medium          # small | medium | large
# PHI_GATEWAY_PROMPT_VARIANT=auto       # auto | full | compact (auto: compact on small profile)
# PHI_GATEWAY_JAILBREAK_MODEL=meta-llama/Llama-Guard-3-1B
# PHI_GATEWAY_DOMAIN_MODEL=microsoft/Phi-4-mini-instruct
# PHI_GATEWAY_PIPELINE_MODEL=microsoft/Phi-4-mini-instruct
# PHI_GATEWAY_GUARD_MODELS=meta-llama/Llama-Guard-3-1B
# HF_TOKEN=...                      # gated HuggingFace models (Llama Guard, etc.)
# PHI_MAX_SEQ_LENGTH=2048
# PHI_CLASSIFY_MAX_SEQ_LENGTH=2048  # classify forward pass; needs headroom for system prompt + history
# PHI_CLASSIFY_CONCURRENCY=1  # max concurrent classify requests; keep at 1 on ~4 GiB GPUs
# PHI_LOAD_4BIT=true
# HF_CACHE_DIR=~/.cache/huggingface
# DOMAIN_CONFIDENCE_THRESHOLD=0.4  # eval sweep only (scripts/eval_domain_classifier.py); not used for chat blocking

# Convex function env — set via: npx convex env set ... (or npx convex dev --env-file .env.local)
# CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-issuer.clerk.accounts.dev  # required for auth
# SUPER_ADMIN_CLERK_ID=user_...
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=openai/gpt-oss-20b
# GROQ_TITLE_MODEL=llama-3.1-8b-instant
# SELF_IMPROVE_GROQ_MODEL=openai/gpt-oss-20b
# SELF_IMPROVE_GROQ_REASONING_EFFORT=medium  # low|medium|high for gpt-oss-20b
# DOMAIN_GATEWAY_ENABLED=true

# Host-only scripts (not used inside Convex container):
# PHI_GATEWAY_URL=http://localhost:8090

# Do NOT set CONVEX_SELF_HOSTED_* — dev uses `npx convex dev --local` on the host
