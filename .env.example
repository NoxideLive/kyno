# Clerk (frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk sign-in URLs (optional — defaults shown)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Public site URL for Clerk allowedRedirectOrigins (optional — localhost added by default)
# VITE_SITE_URL=https://your-app.example.com
# Also add the same origin in Clerk Dashboard → Configure → Paths → Allowed redirect origins

# Convex (frontend)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex (backend — set in Convex Dashboard or via `npx convex env set`)
# Clerk JWT issuer from Clerk Dashboard → JWT templates → convex → Issuer
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-issuer.clerk.accounts.dev

# Bootstrap: first admin user (Clerk user ID from Clerk Dashboard)
SUPER_ADMIN_CLERK_ID=user_...

# Groq (backend — set in Convex Dashboard or via `npx convex env set`)
# Default chat model: openai/gpt-oss-20b (override with GROQ_MODEL)
GROQ_API_KEY=gsk_...
# GROQ_MODEL=openai/gpt-oss-20b
# Title generation model (smallest/cheapest): llama-3.1-8b-instant
# GROQ_TITLE_MODEL=llama-3.1-8b-instant

# Domain gateway — Phi-4-mini-instruct service (backend — Convex env set)
# PHI_GATEWAY_URL=http://localhost:8090
# DOMAIN_GATEWAY_ENABLED=true
# PHI_GATEWAY_API_KEY=
# DOMAIN_CONFIDENCE_THRESHOLD=0.55
